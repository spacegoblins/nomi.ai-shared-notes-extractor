{
  "manifest_version": 2,
  "name": "Nomi.AI Shared Notes Extractor",
  "version": "1.4",
  "description": "Export and import your Nomi's Shared Notes in multiple formats (.txt, .md, .csv).",
  "browser_specific_settings": {
    "gecko": {
      "id": "nomi.ai-shared-notes-extractor@spacegoblins",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  "permissions": [
    "activeTab",
    "tabs",
    "downloads",
    "storage",
    "*://beta.nomi.ai/*"
  ],
  "browser_action": {
    "default_icon": {
      "48": "icons/icon48.png",
      "96": "icons/icon96.png"
    },
    "default_popup": "popup.html",
    "default_title": "Nomi.AI Shared Notes Extractor"
  },
  "content_scripts": [
    {
      "matches": ["*://beta.nomi.ai/nomis/*/shared-notes*"],
      "js": ["inject.js"],
      "css": ["inject.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "48": "icons/icon48.png",
    "96": "icons/icon96.png"
  }
}
